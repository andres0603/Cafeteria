@page
@model productosModel
@{
    ViewData["Title"] = "productos";
}
<link href="~/css/estilo.css" rel="stylesheet" />

@Html.AntiForgeryToken()
<center>
    <div>
        <form method="POST"
            enctype="multipart/form-data">
            @Html.AntiForgeryToken()

            <div class="dashboard-background">
                <div class="dashboard-container">

            <div class="dashboard-header" align="left">
                <h3 style="color:white">GESTIÓN DE PRODUCTOS</h3>
            </div>

            <div class="action-buttons">
                <input type="submit"
                    value="Refrescar"
                    class="btn-dashboard btn-refresh"
                    asp-page-handler="BtRefrescar" />
                <input type="submit"
                    value="Nuevo"
                    class="btn-dashboard btn-new"
                    asp-page-handler="BtNuevo"
                    disabled="@(Model.producto != null)"/>
                <input type="submit"
                    value="Guardar"
                    class="btn-dashboard btn-save"
                    asp-page-handler="BtGuardar"
                    disabled="@(Model.producto == null)"/>
            </div>

            @if (Model.producto != null)
            {
                <input type="hidden" 
                    asp-for="@Model.producto!.id"/>
                <div>
                
                    <div class="form-group">
                        <label style="color:white">
                            Nombre
                        </label>
                        <div class="col-6">
                            <input id="inNombre"
                                   class="cts_forms form-control"
                                   asp-for="@Model.producto!.nombre" />
                        </div>
                    </div>
                    <div class="form-group">
                        <label style="color:white">
                            Precio
                        </label>
                        <div class="col-6">
                            <input id="inPrecio"
                                   class="cts_forms form-control"
                                   asp-for="@Model.producto!.precio" />
                        </div>
                    </div>
                            <div class="form-group">
                                <label style="color:white">
                                    Descripcion
                                </label>
                                <div class="col-6">
                                    <input id="inDescripcion"
                                           class="cts_forms form-control"
                                           asp-for="@Model.producto!.descripcion" />
                                </div>
                            </div>
                            <div class="form-group">
                                <label style="color:white">
                                   Cantidad
                                </label>
                                <div class="col-6">
                                    <input id="inCantidad"
                                           class="cts_forms form-control"
                                           asp-for="@Model.producto!.cantidad" />
                                </div>
                            </div>
                            <div class="form-group">
                                <label style="color:white">
                                    Imagen
                                </label>
                                <div class="col-6">
                                    <input id="inImagen"
                                           class="cts_forms form-control"
                                           type="file"
                                           accept="image/*"
                                           name="ImagenArchivo" />
                                </div>
                                @if (!string.IsNullOrEmpty(Model.producto!.imageUrl))
                                {
                                    <div class="col-6" style="margin-top:8px">
                                        <img src="@Model.producto!.imageUrl"
                                             alt="Imagen actual"
                                             style="max-width:150px; max-height:150px; border-radius:8px;" />
                                    </div>
                                }
                            </div>
                            <div class="form-group">
                                <label style="color:white">
                                    Categoria
                                </label>
                                <div class="col-6">
                                    <select id="seCategoria"
                                            class="cts_forms form-control"
                                            asp-for="@Model.producto!.categoria"
                                            asp-items="@(new SelectList(Model.ListaCategorias, "id", "nombre"))">
                                    </select>

                                </div>
                            </div>

                    </div>
            }

            
            @if (ViewData.ContainsKey("Mensaje"))
            {
                @await Html.PartialAsync("../Emergentes/Mensajes.cshtml");
            }

            @if (Model.producto != null && Model.Borrando)
            {
                <div class='popup'>
                    <div class='pp_ms_inner'>
                        <div style='width:95%'>
                                    <h2 align="left" style="color:white">
                                Mensaje
                            </h2>

                                    <h6 align="left" style="color:white">
                                Desea borrar el producto?
                            </h6>
                                    <h6 align="left" style="color:white">
                                @Model.producto!.nombre
                            </h6>
                            
                            <input type="submit"
                                   value="Cerrar"
                                   asp-page-handler="BtCerrar"
                                   class="btn btn-secondary" />
                            <input type="submit"
                                   value="Borrar"
                                   asp-page-handler="BtBorrar"
                                   class="btn btn-secondary" />
                        </div>
                    </div>
                </div>
            }

            @if (Model != null &&
                 Model.Lista != null &&
                 Model.Lista.Count > 0 )
            {
         <div class="admin-card table-card">
            <div class="table-responsive">
                <table class="custom-table">
                    <tr>
                        <th>
                            Nombre
                        </th>
                        <th>
                            Precio
                        </th>
                        <th>
                            Descripcion
                        </th>
                        <th>
                            Cantidad
                        </th>
                        <th>
                            Imagen
                        </th>
                        <th>
                            Categoria
                        </th>

                    </tr>
                    @foreach (var elemento in Model.Lista)
                    {
                        <tr>
                            <td>
                                @elemento.nombre
                            </td>
                            <td>
                                @elemento.precio
                            </td>
                            <td>
                                @elemento.descripcion
                            </td>
                            <td>
                                @elemento.cantidad
                            </td>
                            <td>
                                @if (!string.IsNullOrEmpty(elemento.imageUrl))
                                {
                                    <img src="@elemento.imageUrl"
                                    alt="@elemento.nombre"
                                    style="width:80px; height:80px; object-fit:contain; border-radius:6px;" />
                                }
                                else
                                {
                                    <span style="color:gray">Sin imagen</span>
                                }
                            </td>
                            <td>
                                @elemento._categorias!.nombre
                            </td>

                            <td>
                                <input type="submit"
                                    value="Modificar"
                                    asp-page-handler="BtModificar"
                                    class="btn-table btn-modify"
                                    asp-route-data="@elemento.id" />
                                <input type="submit"
                                    value="Borrar"
                                    asp-page-handler="BtBorrarVal"
                                    class="btn-table btn-delete"
                                    asp-route-data="@elemento.id" />
                            </td>
                        </tr>
                    }
                </table>
            </div>
         </div>
            }
                </div>
            </div>
        </form>
   
    </div>
</center>