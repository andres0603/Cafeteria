@page
@model producto_proveedorModel
@{
    ViewData["Title"] = "producto proveedor";
}
<link href="~/css/estilo.css" rel="stylesheet" />

@Html.AntiForgeryToken()
<center>
    <div>
        <form method="POST"
            enctype="multipart/form-data">
            @Html.AntiForgeryToken()

            <div class="dashboard-background">
                <div class="dashboard-container">

            <div class="dashboard-header" align="left">
                <h3 style="color:white">GESTIÓN DE LOS PRODUCTOS POR PROVEEDOR</h3>
            </div>

            <div class="action-buttons">
                <input type="submit"
                    value="Refrescar"
                    class="btn-dashboard btn-refresh"
                    asp-page-handler="BtRefrescar" />
                <input type="submit"
                    value="Nuevo"
                    class="btn-dashboard btn-new"
                    asp-page-handler="BtNuevo"
                    disabled="@(Model.producto_proveedor != null)"/>
                <input type="submit"
                    value="Guardar"
                    class="btn-dashboard btn-save"
                    asp-page-handler="BtGuardar"
                    disabled="@(Model.producto_proveedor == null)"/>
            </div>

            @if (Model.producto_proveedor != null)
            {
                <input type="hidden" 
                    asp-for="@Model.producto_proveedor!.id"/>
                <div>
                
                    <div class="form-group">
                        <label style="color:white">
                            Codigo del proveedor
                        </label>
                        <div class="col-6">
                            <input id="inCodProv"
                                   class="cts_forms form-control"
                                   asp-for="@Model.producto_proveedor!.codigoProveedor" />
                        </div>
                    </div>
                    <div class="form-group">
                        <label style="color:white">
                            Precio
                        </label>
                        <div class="col-6">
                            <input id="inPrecio"
                                   class="cts_forms form-control"
                                   asp-for="@Model.producto_proveedor!.precio" />
                        </div>
                    </div>
                            <div class="form-group">
                                <label style="color:white">
                                    Producto
                                </label>
                                <div class="col-6">
                                    <select id="seProducto"
                                            class="cts_forms form-control"
                                            asp-for="@Model.producto_proveedor.idProducto"
                                            asp-items="@(new SelectList(Model.ListaProductos, "id", "nombre"))">
                                    </select>

                                </div>
                            </div>
                            <div class="form-group">
                                <label style="color:white">
                                    Proveedor
                                </label>
                                <div class="col-6">
                                    <select id="seProveedor"
                                            class="cts_forms form-control"
                                            asp-for="@Model.producto_proveedor!.idProveedor"
                                            asp-items="@(new SelectList(Model.ListaProveedores, "id", "nombre"))">
                                    </select>

                                </div>
                            </div>

                    </div>
            }

            
            @if (ViewData.ContainsKey("Mensaje"))
            {
                @await Html.PartialAsync("../Emergentes/Mensajes.cshtml");
            }

            @if (Model.producto_proveedor != null && Model.Borrando)
            {
                <div class='popup'>
                    <div class='pp_ms_inner'>
                        <div style='width:95%'>
                            <h2 align="left" style="color:white">
                                Mensaje
                            </h2>

                                    <h6 align="left" style="color:white">
                                Desea borrar el producto por el proveedor?
                            </h6>
                                    <h6 align="left" style="color:white">
                                @Model.producto_proveedor!.codigoProveedor   
                            </h6>
                            
                            <input type="submit"
                                   value="Cerrar"
                                   asp-page-handler="BtCerrar"
                                   class="btn btn-secondary" />
                            <input type="submit"
                                   value="Borrar"
                                   asp-page-handler="BtBorrar"
                                   class="btn btn-secondary" />
                        </div>
                    </div>
                </div>
            }

            @if (Model != null &&
                 Model.Lista != null &&
                 Model.Lista.Count > 0 )
            {
         <div class="admin-card table-card">
            <div class="table-responsive">
                <table class="custom-table">
                    <tr>
                        <th>
                            Codigo del proveedor
                        </th>
                        <th>
                            Precio
                        </th>
                        <th>
                            Producto
                        </th>
                        <th>
                            Proveedor
                        </th>

                    </tr>
                    @foreach (var elemento in Model.Lista)
                    {
                        <tr>
                            <td>
                                @elemento.codigoProveedor
                            </td>
                            <td>
                                @elemento.precio
                            </td>
                            <td>
                                @elemento._producto!.nombre
                            </td>
                            <td>
                                @elemento._proveedor!.nombre
                            </td>

                            <td>
                                <input type="submit"
                                    value="Modificar"
                                    asp-page-handler="BtModificar"
                                    class="btn-table btn-modify"
                                    asp-route-data="@elemento.id" />
                                <input type="submit"
                                    value="Borrar"
                                    asp-page-handler="BtBorrarVal"
                                    class="btn-table btn-delete"
                                    asp-route-data="@elemento.id" />
                            </td>
                        </tr>
                    }
                </table>
            </div>
         </div>
            }
                </div>
            </div>
        </form>
   
    </div>
</center>