@page
@model sedesModel
@{
    ViewData["Title"] = "sedes";
}
<link href="~/css/estilo.css" rel="stylesheet" />
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

@Html.AntiForgeryToken()
<center>
    <div>
        <form method="POST"
            enctype="multipart/form-data">
            @Html.AntiForgeryToken()

            <div class="dashboard-background">
                <div class="dashboard-container">

            <div class="dashboard-header" align="left">
                <h3 style="color:white">GESTIÓN DE SEDES</h3>
            </div>

            <div class="action-buttons">
                <input type="submit"
                    value="Refrescar"
                    class="btn-dashboard btn-refresh"
                    asp-page-handler="BtRefrescar" />
                <input type="submit"
                    value="Nuevo"
                    class="btn-dashboard btn-new"
                    asp-page-handler="BtNuevo"
                    disabled="@(Model.sede != null)"/>
                <input type="submit"
                    value="Guardar"
                    class="btn-dashboard btn-save"
                    asp-page-handler="BtGuardar"
                    disabled="@(Model.sede == null)"/>
            </div>

            @if (Model.sede != null)
            {
                <input type="hidden" 
                    asp-for="@Model.sede!.id"/>
                <div>
                
                    <div class="form-group">
                        <label style="color:white">
                            Nombre
                        </label>
                        <div class="col-6">
                            <input id="inNombre"
                                   class="cts_forms form-control"
                                   asp-for="@Model.sede!.nombre" />
                        </div>
                    </div>
                    <div class="form-group">
                        <label style="color:white">
                            Fecha de fundacion
                        </label>
                        <div class="col-6">
                            <input type="date"
                                   id="inFecha"
                                   class="cts_forms form-control"
                                   asp-for="@Model.sede!.fecha_fundacion" />
                        </div>
                    </div>
                            <div class="form-group">
                                <label style="color:white">
                                    Direccion
                                </label>
                                <div class="col-6">
                                    <input id="inDireccion"
                                           class="cts_forms form-control"
                                           asp-for="@Model.sede!.direccion" />
                                </div>
                            </div>
                            <input type="hidden" asp-for="@Model.sede!.latitud" id="inLatitud" />
                            <input type="hidden" asp-for="@Model.sede!.longitud" id="inLongitud" />

                            <div class="form-group">
                                <label style="color:white">Ubicación en mapa</label>
                                <div class="col-6">
                                    <div id="mapa" style="height:300px; border-radius:8px;"></div>
                                    <small style="color:white">Haz clic en el mapa para marcar la ubicación</small>
                                </div>
                            </div>
                            <div class="form-group">
                                <label style="color:white">
                                    Activo
                                </label>
                                <div class="col-6">
                                    <input type="checkbox"
                                           asp-for="@Model.sede!.activo"
                                           class="form-check-input" />
                                </div>
                            </div>
                    </div>
            }

            
            @if (ViewData.ContainsKey("Mensaje"))
            {
                @await Html.PartialAsync("../Emergentes/Mensajes.cshtml");
            }

            @if (Model.sede != null && Model.Borrando)
            {
                <div class='popup'>
                    <div class='pp_ms_inner'>
                        <div style='width:95%'>
                                    <h2 align="left" style="color:white">
                                Mensaje
                            </h2>

                                    <h6 align="left" style="color:white">
                                Desea borrar el sede?
                            </h6>
                                    <h6 align="left" style="color:white">
                                @Model.sede!.nombre
                            </h6>
                            
                            <input type="submit"
                                   value="Cerrar"
                                   asp-page-handler="BtCerrar"
                                   class="btn btn-secondary" />
                            <input type="submit"
                                   value="Borrar"
                                   asp-page-handler="BtBorrar"
                                   class="btn btn-secondary" />
                        </div>
                    </div>
                </div>
            }

            @if (Model != null &&
                 Model.Lista != null &&
                 Model.Lista.Count > 0 )
            {
         <div class="admin-card table-card">
            <div class="table-responsive">
                <table class="custom-table">
                    <tr>
                        <th>
                            Nombre
                        </th>
                        <th>
                            Fecha de fundacion
                        </th>
                        <th>
                            Direccion
                        </th>
                        <th>
                            Activo
                        </th>
                        <th>
                            Ubicacion
                        </th>

                    </tr>
                    @foreach (var elemento in Model.Lista)
                    {
                        <tr>
                            <td>
                                @elemento.nombre
                            </td>
                            <td>
                                @elemento.fecha_fundacion.ToString("dd/mm/yyyy")
                            </td>
                            <td>
                                @elemento.direccion
                            </td>

                            <td>
                                @elemento.activo
                            </td>
                            <td>
                                @if (elemento.latitud != null && elemento.longitud != null)
                                {
                                    <a href="https://www.openstreetmap.org/?mlat=@elemento.latitud&mlon=@elemento.longitud"
                                        target="_blank"
                                        style="color:#f0a500">
                                        Ver en mapa
                                    </a>
                                }
                                else
                                {
                                    <span style="color:gray">Sin ubicación</span>
                                }
                            </td>
                            <td>
                                <input type="submit"
                                    value="Modificar"
                                    asp-page-handler="BtModificar"
                                    class="btn-table btn-modify"
                                    asp-route-data="@elemento.id" />
                                <input type="submit"
                                    value="Borrar"
                                    asp-page-handler="BtBorrarVal"
                                    class="btn-table btn-delete"
                                    asp-route-data="@elemento.id" />
                            </td>
                        </tr>
                    }
                </table>
            </div>
         </div>
            }
                </div>
            </div>
        </form>
   
    </div>
    @if (Model.sede != null)
    {
        <script>
            var lat = parseFloat(document.getElementById('inLatitud').value) || 6.2442;
        var lng = parseFloat(document.getElementById('inLongitud').value) || -75.5812;

        var mapa = L.map('mapa').setView([lat, lng], 13);

        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            attribution: '© OpenStreetMap'
        }).addTo(mapa);

        var marcador = L.marker([lat, lng]).addTo(mapa);

        mapa.on('click', function(e) {
            marcador.setLatLng(e.latlng);
            document.getElementById('inLatitud').value = e.latlng.lat.toFixed(6);
            document.getElementById('inLongitud').value = e.latlng.lng.toFixed(6);
        });
    </script>
    }
</center>