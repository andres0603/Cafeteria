@page
@model tareasModel
@{
    ViewData["Title"] = "tareas";
}
<link href="~/css/estilo.css" rel="stylesheet" />

@Html.AntiForgeryToken()
<center>
    <div>
        <form method="POST"
            enctype="multipart/form-data">
            @Html.AntiForgeryToken()

            <div class="dashboard-background">
                <div class="dashboard-container">

            <div class="dashboard-header" align="left">
                <h3 style="color:white">GESTIÓN DE TAREAS</h3>
            </div>

            <div class="action-buttons">
                <input type="submit"
                    value="Refrescar"
                    class="btn-dashboard btn-refresh"
                    asp-page-handler="BtRefrescar" />
                <input type="submit"
                    value="Nuevo"
                    class="btn-dashboard btn-new"
                    asp-page-handler="BtNuevo"
                    disabled="@(Model.tarea != null)"/>
                <input type="submit"
                    value="Guardar"
                    class="btn-dashboard btn-save"
                    asp-page-handler="BtGuardar"
                    disabled="@(Model.tarea == null)"/>
            </div>

            @if (Model.tarea != null)
            {
                <input type="hidden" 
                    asp-for="@Model.tarea!.id"/>
                <div>
                
                    <div class="form-group">
                        <label style="color:white">
                            Nombre
                        </label>
                        <div class="col-6">
                            <input id="inNombre"
                                   class="cts_forms form-control"
                                   asp-for="@Model.tarea!.nombre" />
                        </div>
                    </div>
                    <div class="form-group">
                        <label style="color:white">
                            Fecha de asignacion
                        </label>
                        <div class="col-6">
                            <input type="date"
                                   id="inFecha"
                                   class="cts_forms form-control"
                                   asp-for="@Model.tarea!.fechaAsignacion" />
                        </div>
                    </div>
                            <div class="form-group">
                                <label style="color:white">
                                    Observaciones
                                </label>
                                <div class="col-6">
                                    <input id="inObservaciones"
                                           class="cts_forms form-control"
                                           asp-for="@Model.tarea!.observaciones" />
                                </div>
                            </div>
                            <div class="form-group">
                                <label style="color:white">
                                    Activo
                                </label>
                                <div class="col-6">
                                    <input type="checkbox"
                                           asp-for="@Model.tarea!.activo"
                                           class="form-check-input" />
                                </div>
                            </div>
                            <div class="form-group">
                                <label style="color:white">
                                    Empleado
                                </label>
                                <div class="col-6">
                                    <select id="seEmpleado"
                                            class="cts_forms form-control"
                                            asp-for="@Model.tarea!.empleados"
                                            asp-items="@(new SelectList(Model.ListaEmpleados, "id", "nombre"))">
                                    </select>

                                </div>
                            </div>

                    </div>
            }

            
            @if (ViewData.ContainsKey("Mensaje"))
            {
                @await Html.PartialAsync("../Emergentes/Mensajes.cshtml");
            }

            @if (Model.tarea != null && Model.Borrando)
            {
                <div class='popup'>
                    <div class='pp_ms_inner'>
                        <div style='width:95%'>
                                    <h2 align="left" style="color:white">
                                Mensaje
                            </h2>

                                    <h6 align="left" style="color:white">
                                Desea borrar la tarea?
                            </h6>
                                    <h6 align="left" style="color:white">
                                @Model.tarea!.nombre
                            </h6>
                            
                            <input type="submit"
                                   value="Cerrar"
                                   asp-page-handler="BtCerrar"
                                   class="btn btn-secondary" />
                            <input type="submit"
                                   value="Borrar"
                                   asp-page-handler="BtBorrar"
                                   class="btn btn-secondary" />
                        </div>
                    </div>
                </div>
            }

            @if (Model != null &&
                 Model.Lista != null &&
                 Model.Lista.Count > 0 )
            {
         <div class="admin-card table-card">
            <div class="table-responsive">
                <table class="custom-table">
                    <tr>
                        <th>
                            Nombre
                        </th>
                        <th>
                            Fecha de asignacion
                        </th>
                        <th>
                            Observaciones
                        </th>
                        <th>
                            Empleados
                        </th>
                        <th>
                            Activo
                        </th>

                    </tr>
                    @foreach (var elemento in Model.Lista)
                    {
                        <tr>
                            <td>
                                @elemento.nombre
                            </td>
                            <td>
                                @elemento.fechaAsignacion
                            </td>
                            <td>
                                @elemento.observaciones
                            </td>
                            <td>
                                @elemento._empleados!.nombre
                            </td>
                            <td>
                                @elemento.activo
                            </td>

                            <td>
                                <input type="submit"
                                    value="Modificar"
                                    asp-page-handler="BtModificar"
                                    class="btn-table btn-modify"
                                    asp-route-data="@elemento.id" />
                                <input type="submit"
                                    value="Borrar"
                                    asp-page-handler="BtBorrarVal"
                                    class="btn-table btn-delete"
                                    asp-route-data="@elemento.id" />
                            </td>
                        </tr>
                    }
                </table>
            </div>
         </div>
            }
                </div>
            </div>
        </form>
   
    </div>
</center>